//   panPreview        String?   // URL or Base64
//   licensePreview    String?   // URL or Base64
//   salaryRate        Float?
//   // Define other fields and relationships as needed
// }

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String?
}
